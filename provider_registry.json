      "reasoning": {
        "path": "extra_body.reasoning.effort",
        "allowed_values": ["minimal", "low", "medium", "high", "xhigh"],
        "value_map": {
          "none": "none"
        }
      },
      "notes": "OpenRouter reasoning object API on OpenAI-compatible chat completions."
    },
