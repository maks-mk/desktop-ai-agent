{
  "schema_version": 1,
  "data_version": 1,
  "providers": [
    {
      "id": "openai",
      "enabled": true,
      "priority": 100,
      "match": ["api.openai.com"],
      "match_type": "exact",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning.effort",
        "allowed_values": ["minimal", "low", "medium", "high", "xhigh"],
        "value_map": {},
        "extra_fields": {
          "reasoning.summary": "auto"
        }
      },
      "notes": "Native OpenAI Responses API through LangChain ChatOpenAI."
    },
    {
      "id": "openrouter",
      "enabled": true,
