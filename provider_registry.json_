{
  "schema_version": 1,
  "data_version": 2,
  "providers": [
    {
      "id": "openai",
      "enabled": true,
      "priority": 100,
      "match": [
        "api.openai.com"
      ],
      "match_type": "exact",
      "supports_reasoning": true,
      "model_match": {
        "prefix": [
          "gpt-5",
          "o1",
          "o3",
          "o4"
        ]
      },
      "validation": "map",
      "reasoning": {
        "path": "reasoning.effort",
        "allowed_values": [
          "minimal",
          "low",
          "medium",
          "high",
          "xhigh"
        ],
        "value_map": {},
        "extra_fields": {
          "reasoning.summary": "auto"
        }
      },
      "notes": "Native OpenAI Responses API through LangChain ChatOpenAI."
    },
    {
      "id": "openrouter",
      "enabled": true,
      "priority": 90,
      "match": [
        "openrouter.ai"
      ],
      "match_type": "suffix",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "extra_body.reasoning.effort",
        "allowed_values": [
          "minimal",
          "low",
          "medium",
          "high",
          "xhigh"
        ],
        "value_map": {
          "none": "none"
        }
      },
      "notes": "OpenRouter reasoning object API on OpenAI-compatible chat completions."
    },
    {
      "id": "ollama_cloud",
      "enabled": true,
      "priority": 85,
      "match": [
        "ollama.com"
      ],
      "match_type": "suffix",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning_effort",
        "allowed_values": [
          "low",
          "medium",
          "high"
        ],
        "value_map": {
          "minimal": "low",
          "xhigh": "high"
        }
      },
      "notes": "Hosted Ollama cloud API."
    },
    {
      "id": "fireworks",
      "enabled": true,
      "priority": 80,
      "match": [
        "api.fireworks.ai"
      ],
      "match_type": "suffix",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning_effort",
        "allowed_values": [
          "low",
          "medium",
          "high"
        ],
        "value_map": {
          "minimal": "low",
          "xhigh": "high"
        }
      },
      "notes": "Fireworks OpenAI-compatible reasoning API."
    },
    {
      "id": "nvidia_nim",
      "enabled": true,
      "priority": 70,
      "match": [
        "integrate.api.nvidia.com",
        "api.nvidia.com"
      ],
      "match_type": "suffix",
      "supports_reasoning": true,
      "validation": "map",
      "model_match": {
        "contains": [
          "deepseek-r1",
          "deepseek-v4",
          "deepseek-v3",
          "deepseek-prover",
          "glm-5",
          "glm-4.7",
          "kimi-k2",
          "qwen3",
          "gemma-4",
          "gpt-oss"
        ]
      },
      "reasoning": {
        "path": "extra_body.chat_template_kwargs.enable_thinking",
        "allowed_values": [
          "true"
        ],
        "value_map": {
          "minimal": "true",
          "low": "true",
          "medium": "true",
          "high": "true",
          "xhigh": "true",
          "max": "true"
        },
        "extra_fields": {
          "extra_body.chat_template_kwargs.clear_thinking": false
        }
      },
      "notes": "NVIDIA NIM uses chat_template_kwargs to enable thinking (not reasoning_effort). DeepSeek V3.x: {thinking:true}. DeepSeek V4: {thinking:true, reasoning_effort:high|max}. GLM-5/4.7: {enable_thinking:true, clear_thinking:false}. Kimi-K2: {thinking:true}. Qwen3/Gemma-4: {enable_thinking:true}. Models not in model_match either do not support thinking or always think regardless. reasoning_content appears in streaming delta when thinking is enabled. chat_template_kwargs is sent via extra_body to avoid LangChain UserWarning about non-default parameters. Ref: github.com/xRyul/pi-nvidia-nim, NVIDIA docs."
    },
    {
      "id": "aihubmix",
      "enabled": true,
      "priority": 70,
      "match": [
        "aihubmix.com"
      ],
      "match_type": "suffix",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning_effort",
        "allowed_values": [
          "minimal",
          "low",
          "medium",
          "high",
          "xhigh"
        ],
        "value_map": {
          "none": "none"
        }
      },
      "notes": "AIHubMix unified OpenAI-compatible chat reasoning uses top-level reasoning_effort."
    },
    {
      "id": "baai",
      "enabled": true,
      "priority": 70,
      "match": [
        "api.b.ai"
      ],
      "match_type": "exact",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning_effort",
        "allowed_values": [
          "low",
          "medium",
          "high"
        ],
        "value_map": {
          "minimal": "low",
          "xhigh": "high"
        }
      },
      "notes": "Experimental: api.b.ai OpenAI-compatible models were observed streaming delta.reasoning/reasoning_content; top-level reasoning_effort is used conservatively."
    },
    {
      "id": "mistral",
      "enabled": true,
      "priority": 60,
      "match": [
        "api.mistral.ai"
      ],
      "match_type": "exact",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning_effort",
        "allowed_values": [
          "high"
        ],
        "value_map": {
          "minimal": "high",
          "low": "high",
          "medium": "high",
          "xhigh": "high"
        }
      },
      "notes": "Mistral adjustable reasoning currently documents high/none for supported models; none is handled globally by MODEL_REASONING_EFFORT=none."
    },
    {
      "id": "modelscope_global",
      "enabled": true,
      "priority": 60,
      "match": [
        "api-inference.modelscope.ai"
      ],
      "match_type": "exact",
      "supports_reasoning": false,
      "validation": "passthrough",
      "notes": "Conservative default: do not send undocumented reasoning fields."
    },
    {
      "id": "modelscope_cn",
      "enabled": true,
      "priority": 60,
      "match": [
        "api-inference.modelscope.cn"
      ],
      "match_type": "exact",
      "supports_reasoning": false,
      "validation": "passthrough",
      "notes": "Conservative default: do not send undocumented reasoning fields."
    },
    {
      "id": "freemodel",
      "enabled": true,
      "priority": 60,
      "match": [
        "api.freemodel.dev"
      ],
      "match_type": "exact",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning.effort",
        "allowed_values": [
          "minimal",
          "low",
          "medium",
          "high"
        ],
        "value_map": {
          "xhigh": "high"
        },
        "extra_fields": {
          "reasoning.summary": "auto"
        }
      },
      "notes": "Experimental: testing OpenAI-style reasoning payload for GPT-5 models through freemodel.dev."
    },
	{
      "id": "ai-router",
      "enabled": true,
      "priority": 60,
      "match": [
        "api.ai-router.dev"
      ],
      "match_type": "exact",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning.effort",
        "allowed_values": [
          "minimal",
          "low",
          "medium",
          "high"
        ],
        "value_map": {
          "xhigh": "high"
        },
        "extra_fields": {
          "reasoning.summary": "auto"
        }
      },
      "notes": "Experimental: testing OpenAI-style reasoning payload for GPT-5 models through api.ai-router.dev."
    },
    {
      "id": "freetheai",
      "enabled": true,
      "priority": 60,
      "match": [
        "api.freetheai.xyz"
      ],
      "match_type": "exact",
      "supports_reasoning": true,
      "validation": "map",
      "reasoning": {
        "path": "reasoning.effort",
        "allowed_values": [
          "minimal",
          "low",
          "medium",
          "high"
        ],
        "value_map": {
          "xhigh": "high"
        },
        "extra_fields": {
          "reasoning.summary": "auto"
        }
      },
      "notes": "Experimental: OpenAI-style reasoning payload for FreeTheAI models; bbl/gemini-3.5-flash and wsf/kimi-k2.6 use the same provider-level reasoning format."
    }
  ]
}
